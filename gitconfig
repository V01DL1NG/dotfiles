[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[fetch]
	prune = true

[rerere]
	enabled = true

[merge]
	conflictstyle = zdiff3

[diff]
	algorithm = histogram
	colorMoved = default

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	syntax-theme = gruvbox-dark

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[alias]
	lg = log --graph --oneline --decorate --all
	amend = commit --amend --no-edit
	undo = reset --soft HEAD~1
	branches = branch --sort=-committerdate --format='%(committerdate:relative)\t%(refname:short)'
	st = status --short --branch
	last = log -1 --stat
