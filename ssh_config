# =============================================================================
# Global defaults
# =============================================================================

Host *
    # Use macOS Keychain for SSH key passphrases
    AddKeysToAgent yes
    UseKeychain yes
    IdentityFile ~/.ssh/id_ed25519

    # Connection keepalive (prevents drops on idle connections)
    ServerAliveInterval 60
    ServerAliveCountMax 3

    # Reuse connections (faster subsequent SSH/SCP/Git to same host)
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%r@%h-%p
    ControlPersist 600

    # Security defaults
    HashKnownHosts yes

